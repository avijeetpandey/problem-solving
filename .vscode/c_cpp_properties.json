{
    "configurations": [
        {
            "name": "Linux",
            "includePath": [
                "${workspaceFolder}/**",
                "/usr/include/x86_64-linux-gnu/c++/9",
                "/usr/include/c++/9"
            ],
            "defines": [],
            "compilerPath": "/usr/bin/g++",
            "cStandard": "gnu11",
            "cppStandard": "gnu++98",
            "intelliSenseMode": "linux-gcc-x64",
            "compilerArgs": [],
            "browse": {
                "path": [
                    "${workspaceFolder}/**",
                    "/usr/include/x86_64-linux-gnu/c++/9",
                    "/usr/include/c++/9"
                ],
                "limitSymbolsToIncludedHeaders": true
            }
        },
        {
            "name": "Ubuntu",
            "includePath": [
                "${workspaceFolder}/**"
            ],
            "defines": [],
            "compilerPath": "/home/linuxbrew/.linuxbrew/bin/gcc-5",
            "cStandard": "gnu11",
            "cppStandard": "gnu++98",
            "intelliSenseMode": "${default}"
        }
    ],
    "version": 4
}